<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/grid_item_bg"
    android:layout_margin="8dp"
    android:padding="16dp"
    android:orientation="horizontal"
    android:elevation="2dp">

    <FrameLayout
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="12dp"
        android:layout_gravity="center_vertical">

        <ImageView
            android:id="@+id/language_icon_image"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:scaleType="centerInside"
            android:visibility="gone" />

        <TextView
            android:id="@+id/language_icon_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textSize="28sp"
            android:gravity="center"
            android:visibility="gone" />

    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/language_name_ar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="سي بلس بلس"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#193559" />

        <TextView
            android:id="@+id/language_name_en"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="C++"
            android:textSize="12sp"
            android:textColor="#7F8C8D" />

    </LinearLayout>

    <ImageView
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_arrow"
        android:layout_gravity="center_vertical" />

</LinearLayout>