<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/grid_item_bg"
    android:layout_margin="6dp"
    android:padding="16dp"
    android:orientation="vertical"
    android:gravity="center"
    android:elevation="2dp">

    <FrameLayout
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:background="@drawable/icon_circle_bg"
        android:layout_marginBottom="12dp">

        <ImageView
            android:id="@+id/grid_item_icon_image"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:scaleType="centerInside"
            android:visibility="gone" />

        <TextView
            android:id="@+id/grid_item_icon_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textSize="32sp"
            android:gravity="center"
            android:visibility="visible" />

    </FrameLayout>

    <TextView
        android:id="@+id/grid_item_title_ar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="أساسيات"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#1A2C3E"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/grid_item_title_en"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Basics"
        android:textSize="12sp"
        android:textColor="#7F8C8D"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end"
        android:visibility="gone" />

    <TextView
        android:id="@+id/grid_item_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0"
        android:textSize="11sp"
        android:textColor="#5ED6C1"
        android:layout_marginTop="10dp"
        android:background="#E8F8F5"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:gravity="center"
        android:textStyle="bold" />

</LinearLayout>