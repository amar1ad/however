<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical"
	android:background="@color/background_main">
	<LinearLayout
		android:id="@+id/layout_header"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:paddingLeft="24dp"
		android:paddingTop="40dp"
		android:paddingRight="24dp"
		android:paddingBottom="24dp"
		android:background="@drawable/header_gradient_pro"
		android:orientation="vertical"
		android:elevation="12dp">
		<LinearLayout
			android:id="@+id/linear316"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:gravity="center_vertical"
			android:orientation="horizontal">
			<LinearLayout
				android:id="@+id/linear317"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:orientation="vertical"
				android:layout_weight="1">
				<TextView
					android:id="@+id/textview102"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="مرحباً بك في"
					android:textSize="13sp"
					android:textColor="#B0D4FF"
					android:letterSpacing="0.05" />
				<LinearLayout
					android:id="@+id/linear318"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginTop="6dp"
					android:orientation="horizontal">
					<TextView
						android:id="@+id/textview8"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:text="المبرمج"
						android:textSize="28sp"
						android:textStyle="bold"
						android:textColor="#5ED6C1"
						android:shadowColor="#0F2442"
						android:shadowDx="2"
						android:shadowDy="2"
						android:shadowRadius="4"
						android:letterSpacing="-0.02" />
					<TextView
						android:id="@+id/textview9"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:text="قاموس"
						android:textSize="28sp"
						android:textStyle="bold"
						android:textColor="#FFFFFF"
						android:layout_marginStart="6dp"
						android:shadowColor="#0F2442"
						android:shadowDx="2"
						android:shadowDy="2"
						android:shadowRadius="4"
						android:letterSpacing="-0.02" />
				</LinearLayout>
				<TextView
					android:id="@+id/textview10"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginTop="6dp"
					android:text="أول قاموس تفاعلي للمبرمجين"
					android:textSize="12sp"
					android:textColor="#CCE0FF"
					android:letterSpacing="0.02" />
			</LinearLayout>
			<ImageButton
				android:id="@+id/btn_share"
				android:layout_width="44dp"
				android:layout_height="44dp"
				android:padding="10dp"
				android:background="@drawable/glass_button_bg_pro"
				android:src="@drawable/ic_share"
				android:scaleType="centerInside"
				android:stateListAnimator="@animator/button_scale" />
		</LinearLayout>
		<LinearLayout
			android:id="@+id/linear319"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="20dp"
			android:padding="14dp"
			android:background="#FFFFFF"
			android:gravity="center_horizontal|center_vertical"
			android:orientation="horizontal"
			android:weightSum="3"
			android:elevation="2dp">
			<LinearLayout
				android:id="@+id/linear320"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="vertical"
				android:layout_weight="1">
				<TextView
					android:id="@+id/stats_categories"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="0"
					android:textSize="22sp"
					android:textStyle="bold"
					android:textColor="#5ED6C1" />
				<TextView
					android:id="@+id/textview103"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginTop="4dp"
					android:text="تصنيف"
					android:textSize="12sp"
					android:textColor="#5ED6C1" />
			</LinearLayout>
			<View
				android:id="@+id/view321"
				android:layout_width="2dp"
				android:layout_height="35dp"
				android:background="#FFFFFF" />
			<LinearLayout
				android:id="@+id/linear322"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="vertical"
				android:layout_weight="1">
				<TextView
					android:id="@+id/stats_terms"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="0"
					android:textSize="22sp"
					android:textStyle="bold"
					android:textColor="#5ED6C1" />
				<TextView
					android:id="@+id/textview104"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginTop="4dp"
					android:text="مصطلح"
					android:textSize="12sp"
					android:textColor="#5ED6C1" />
			</LinearLayout>
			<View
				android:id="@+id/view323"
				android:layout_width="2dp"
				android:layout_height="35dp"
				android:background="#FFFFFF" />
			<LinearLayout
				android:id="@+id/linear324"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="vertical"
				android:layout_weight="1">
				<TextView
					android:id="@+id/stats_last_update"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="--"
					android:textSize="15sp"
					android:textStyle="bold"
					android:textColor="#5ED6C1" />
				<TextView
					android:id="@+id/textview105"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginTop="4dp"
					android:text="آخر تحديث"
					android:textSize="11sp"
					android:textColor="#5ED6C1" />
			</LinearLayout>
		</LinearLayout>
	</LinearLayout>
	<LinearLayout
		android:id="@+id/linear_search_container"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_margin="16dp"
		android:padding="4dp"
		android:background="@drawable/search_bg_pro"
		android:gravity="center_vertical"
		android:orientation="horizontal"
		android:elevation="6dp">
		<SearchView
			android:id="@+id/search_view"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:queryHint="ابحث_عن_لغة_أو_مصطلح..."
			android:iconifiedByDefault="false" />
	</LinearLayout>
	<HorizontalScrollView
		android:id="@+id/hscroll1"
		android:layout_width="match_parent"
		android:layout_height="wrap_content">
		<LinearLayout
			android:id="@+id/linear325"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginBottom="10dp"
			android:orientation="horizontal"
			android:weightSum="5">
			<Button
				android:id="@+id/btn_refresh_data"
				android:layout_width="0dp"
				android:layout_height="48dp"
				android:background="@drawable/btn_green_gradient"
				android:text=" تحديث"
				android:textSize="12sp"
				android:textStyle="bold"
				android:textColor="#FFFFFF"
				android:layout_weight="1"
				android:layout_marginEnd="8dp"
				android:stateListAnimator="@animator/button_scale" />
			<Button
				android:id="@+id/btn_about"
				android:layout_width="0dp"
				android:layout_height="48dp"
				android:background="@drawable/btn_purple_gradient"
				android:text=" عن التطبيق"
				android:textSize="12sp"
				android:textStyle="bold"
				android:textColor="#FFFFFF"
				android:layout_weight="1"
				android:layout_marginEnd="8dp"
				android:stateListAnimator="@animator/button_scale" />
			<Button
				android:id="@+id/btn_check_update"
				android:layout_width="0dp"
				android:layout_height="48dp"
				android:background="@drawable/btn_blue_gradient"
				android:text=" تحديثات"
				android:textSize="12sp"
				android:textStyle="bold"
				android:textColor="#FFFFFF"
				android:layout_weight="1"
				android:layout_marginStart="8dp"
				android:layout_marginEnd="8dp"
				android:stateListAnimator="@animator/button_scale" />
			<Button
				android:id="@+id/btn_language"
				android:layout_width="60dp"
				android:layout_height="48dp"
				android:layout_marginRight="3dp"
				android:background="@drawable/btn_purple_gradient"
				android:text="ar"
				android:textSize="16sp"
				android:textStyle="bold"
				android:textColor="#FFFFFF"
				android:layout_marginStart="8dp"
				android:stateListAnimator="@animator/button_scale" />
			<Button
				android:id="@+id/btn_favorites"
				android:layout_width="0dp"
				android:layout_height="48dp"
				android:background="@drawable/btn_orange_gradient"
				android:text=" مفضلة"
				android:textSize="12sp"
				android:textStyle="bold"
				android:textColor="#FFFFFF"
				android:layout_weight="1"
				android:layout_marginEnd="8dp"
				android:stateListAnimator="@animator/button_scale" />
			<Button
				android:id="@+id/btn_languages"
				android:layout_width="0dp"
				android:layout_height="48dp"
				android:background="@drawable/btn_blue_gradient"
				android:text=" لغات"
				android:textSize="12sp"
				android:textStyle="bold"
				android:textColor="#FFFFFF"
				android:layout_weight="1"
				android:layout_marginStart="8dp"
				android:layout_marginEnd="8dp"
				android:stateListAnimator="@animator/button_scale" />
			<Button
				android:id="@+id/btn_notifications"
				android:layout_width="60dp"
				android:layout_height="48dp"
				android:background="@drawable/btn_purple_gradient"
				android:text="🔔"
				android:textSize="16sp"
				android:textStyle="bold"
				android:textColor="#FFFFFF"
				android:layout_marginStart="8dp"
				android:stateListAnimator="@animator/button_scale" />
		</LinearLayout>
	</HorizontalScrollView>
	<FrameLayout
		android:id="@+id/frame_layout328"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:layout_marginTop="4dp">
		<ImageView
			android:id="@+id/img_bg_list"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:padding="40dp"
			android:src="@drawable/program"
			android:scaleType="centerInside"
			android:layout_gravity="center_horizontal|center_vertical"
			android:alpha="0.3" />
		<GridView
			android:id="@+id/gridview1"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:padding="10dp"
			android:numColumns="2"
			android:verticalSpacing="14dp"
			android:horizontalSpacing="12dp"
			android:scrollbars="none"
			android:clipToPadding="false"
			android:overScrollMode="never" />
		<ProgressBar
			android:id="@+id/progressBar"
			android:layout_width="56dp"
			android:layout_height="56dp"
			android:indeterminate="true"
			style="?android:progressBarStyle"
			android:layout_gravity="center_horizontal|center_vertical"
			android:indeterminateTint="#5ED6C1"
			android:visibility="gone" />
	</FrameLayout>
</LinearLayout>
