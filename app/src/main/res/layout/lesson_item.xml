<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/grid_item_bg"
    android:layout_margin="8dp"
    android:padding="16dp"
    android:orientation="horizontal"
    android:elevation="2dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/lesson_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="عنوان الدرس"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#193559" />

        <TextView
            android:id="@+id/lesson_description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="وصف الدرس"
            android:textSize="12sp"
            android:textColor="#7F8C8D"
            android:layout_marginTop="4dp"
            android:maxLines="2" />

    </LinearLayout>

    <TextView
        android:id="@+id/lesson_order"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:text="1"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#5ED6C1"
        android:gravity="center"
        android:background="#E8F8F5"
        android:padding="4dp" />

</LinearLayout>